{
  "name": "cc-llm4zotero-adapter",
  "version": "0.1.0",
  "description": "Adapter that connects llm-for-zotero agent frontend semantics to Claude Code runtime",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo:llm4zotero": "tsx examples/llm4zotero-runturn-demo.ts",
    "serve:bridge": "tsx bin/start-bridge-server.ts --host 127.0.0.1 --port 8787",
    "serve:bridge:zotero": "ADAPTER_RUNTIME_CWD=\"$HOME/Zotero/agent-runtime\" ADAPTER_STATE_DIR=\"$HOME/Zotero/agent-state\" tsx bin/start-bridge-server.ts --host 127.0.0.1 --port 18787"
  },
  "keywords": [
    "zotero",
    "claude-code",
    "adapter",
    "agent"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.87"
  }
}
